---
import { getCollection } from 'astro:content';
import { GoBack } from '~/components/ui'
import Base from '~/layouts/Base.astro'

const posts = await getCollection('blog').then((data) =>
  data.sort((a, b) => a.data.sortOrder - b.data.sortOrder),
)
---

<Base>
  <article>
    <div class="h-20"></div>

    <GoBack />

    <h1>Blog</h1>
    <p>Posts:</p>
    <ul>
      {
        posts.map((post) => (
          <li class="flex justify-between !ml-0">
            <div>
              <a href={`/blog/${post.slug}`} class="text-yellow text-lg">
                {post.data.title}
              </a>
              <p class="small">{post.data.description}</p>
            </div>
            <time>
              <i>{post.data.pubDate.toLocaleDateString()} - {post.data.pubDate.toLocaleTimeString()}</i>
            </time>
          </li>
        ))
      }
    </ul>
  </article>
</Base>
